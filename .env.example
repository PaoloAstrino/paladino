# =============================================================================
# PALADINO ENVIRONMENT CONFIGURATION
# Copy this file to .env and update with your values BEFORE running
# 
# ⚠️ SECURITY WARNING: Never commit .env file to version control!
# =============================================================================

# -----------------------------------------------------------------------------
# NEO4J CONFIGURATION (REQUIRED - Change defaults before production!)
# -----------------------------------------------------------------------------
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j

# SECURITY FIX (SEC-001): Generate a secure password (min 20 characters)
# Recommended: openssl rand -base64 32
NEO4J_PASSWORD=your_secure_password_here_CHANGE_ME

# Database name (usually 'neo4j')
NEO4J_DATABASE=neo4j

# Performance tuning (adjust based on available RAM)
# For 16GB system: heap=4G, pagecache=6G
# For 32GB system: heap=8G, pagecache=12G
NEO4J_HEAP_INITIAL=4G
NEO4J_HEAP_MAX=4G
NEO4J_PAGECACHE=6G

# -----------------------------------------------------------------------------
# SECURITY CONFIGURATION (REQUIRED for production)
# -----------------------------------------------------------------------------

# SECURITY FIX (SEC-002): API keys for authentication
# Comma-separated list of valid API keys
# Generate with: openssl rand -hex 16
# Example: API_KEYS=sk_live_abc123def456,sk_live_xyz789uvw012
API_KEYS=

# SECURITY FIX (SEC-005): Allowed CORS origins
# Comma-separated list of allowed domains (no wildcards in production!)
# Example: ALLOWED_ORIGINS=https://your-domain.com,https://admin.your-domain.com
# Development: ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# Rate limiting configuration
API_RATE_LIMIT=100/minute
API_RATE_LIMIT_UNAUTHENTICATED=20/minute

# -----------------------------------------------------------------------------
# LLM CONFIGURATION (Optional - configure via 'paladino configure-llm')
# -----------------------------------------------------------------------------

# Option 1: Ollama (Local) - Recommended for privacy
OLLAMA_BASE_URL=http://localhost:11434
LLM_MODEL=llama3.2
LLM_API_KEY=
LLM_API_BASE=

# Option 2: OpenAI API (uncomment to use)
# OPENAI_API_KEY=sk-proj-...
# LLM_MODEL=gpt-4o

# Option 3: Groq API (uncomment to use)
# GROQ_API_KEY=gsk_...

# Option 4: Anthropic API (uncomment to use)
# ANTHROPIC_API_KEY=sk-ant-...

# -----------------------------------------------------------------------------
# API CONFIGURATION
# -----------------------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4

# Logging configuration
LOG_LEVEL=INFO
LOG_FORMAT=json

# Audit logging (required for production)
ENABLE_AUDIT_LOGGING=true
AUDIT_RETENTION_DAYS=90
AUDIT_LOG_DIR=./audit_logs

# -----------------------------------------------------------------------------
# ETL CONFIGURATION
# -----------------------------------------------------------------------------
ETL_BATCH_SIZE=5000
ETL_MAX_RETRIES=5
ETL_CHECKPOINT_DIR=./checkpoints
ETL_DLQ_DIR=./dlq

# Data sources (Phase 2+)
# ANAC_API_URL=https://dati.anticorruzione.it/opendata/ocds
# OPENCUP_API_URL=https://www.opencup.gov.it/portale/web/opencup/opendata

# -----------------------------------------------------------------------------
# MONITORING & OBSERVABILITY
# -----------------------------------------------------------------------------
ENABLE_METRICS=true
METRICS_PORT=9090

# -----------------------------------------------------------------------------
# DATA QUALITY & COMPLIANCE
# -----------------------------------------------------------------------------
MIN_DATA_QUALITY_SCORE=0.95
MAX_ERROR_RATE=0.01

# GDPR compliance flags
GDPR_MODE=false  # Set to true in EU production deployments
DATA_RETENTION_DAYS=365
